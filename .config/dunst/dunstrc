[global]
    monitor = 0
    follow = keyboard
    width = (320, 460)
    height = (80, 260)
    origin = top-right
    offset = (14, 46)
    notification_limit = 5

    font = JetBrains Mono 11
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    ellipsize = end
    ignore_newline = no
    show_age_threshold = 60

    padding = 12
    horizontal_padding = 14
    text_icon_padding = 12
    frame_width = 2
    gap_size = 8
    separator_height = 0
    corner_radius = 8

    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 0
    progress_bar_min_width = 120
    progress_bar_max_width = 420
    progress_bar_corner_radius = 4

    enable_recursive_icon_lookup = true
    icon_theme = Adwaita
    icon_position = left
    min_icon_size = 32
    max_icon_size = 48

    sort = update
    stack_duplicates = true
    hide_duplicate_count = false
    history_length = 50
    sticky_history = yes
    indicate_hidden = yes
    show_indicators = yes

    dmenu = i3-app-launcher run
    browser = /usr/bin/xdg-open

    title = Dunst
    class = Dunst
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#1d2021"
    foreground = "#a89984"
    frame_color = "#504945"
    highlight = "#8ec07c"
    timeout = 5
    default_icon = dialog-information

[urgency_normal]
    background = "#1d2021"
    foreground = "#ebdbb2"
    frame_color = "#8ec07c"
    highlight = "#8ec07c"
    timeout = 8
    override_pause_level = 30
    default_icon = dialog-information

[urgency_critical]
    background = "#1d2021"
    foreground = "#fbf1c7"
    frame_color = "#fb4934"
    highlight = "#fb4934"
    timeout = 0
    override_pause_level = 60
    default_icon = dialog-warning
