# i3 config file (v4)
#
# Please see https://i3wm.org/docs/userguide.html for a complete reference!

set $mod Mod4

# Font for window titles. The bar uses its own font below.
font pango:JetBrains Mono 10

# Catppuccin Frappe palette.
set $ctp_rosewater #f2d5cf
set $ctp_pink      #f4b8e4
set $ctp_mauve     #ca9ee6
set $ctp_red       #e78284
set $ctp_peach     #ef9f76
set $ctp_yellow    #e5c890
set $ctp_green     #a6d189
set $ctp_teal      #81c8be
set $ctp_blue      #8caaee
set $ctp_lavender  #babbf1
set $ctp_text      #c6d0f5
set $ctp_subtext1  #b5bfe2
set $ctp_subtext0  #a5adce
set $ctp_overlay1  #838ba7
set $ctp_overlay0  #737994
set $ctp_surface1  #51576d
set $ctp_surface0  #414559
set $ctp_base      #303446
set $ctp_mantle    #292c3c
set $ctp_crust     #232634

# Window titlebar spacing.
title_align center
for_window [all] title_format "  %title  "
for_window [all] title_window_icon on
for_window [all] title_window_icon padding 6

# Window colours: border, background, text, indicator, child border.
client.focused          $ctp_mauve    $ctp_base   $ctp_text     $ctp_mauve    $ctp_mauve
client.focused_inactive $ctp_surface0 $ctp_mantle $ctp_subtext1 $ctp_surface0 $ctp_surface0
client.unfocused        $ctp_surface0 $ctp_mantle $ctp_overlay1 $ctp_surface0 $ctp_surface0
client.urgent           $ctp_red      $ctp_base   $ctp_text     $ctp_red      $ctp_red
client.placeholder      $ctp_surface0 $ctp_mantle $ctp_overlay0 $ctp_surface0 $ctp_surface0
client.background       $ctp_base

# This font is widely installed, provides lots of unicode glyphs, right-to-left
# text rendering and scalability on retina/hidpi displays (thanks to pango).
#font pango:DejaVu Sans Mono 8

# Start only the background services this i3 session deliberately uses.
exec_always --no-startup-id ~/.local/bin/i3-autostart

# Keyboard layout. Use the menu to switch between laptop and external layouts.
exec_always --no-startup-id ~/.local/bin/i3-keyboard-layout apply --quiet

# Monitor layout. Auto docks to an external display when one is connected.
exec_always --no-startup-id ~/.local/bin/i3-monitor-layout auto --quiet

# Wallpaper.
exec_always --no-startup-id ~/.local/bin/i3-wallpaper

# Notifications.
exec_always --no-startup-id dunst

# Clipboard manager.
exec_always --no-startup-id ~/.local/bin/i3-start-copyq

# Compositor.
exec_always --no-startup-id ~/.local/bin/i3-start-picom

# xss-lock grabs a logind suspend inhibit lock and will use i3lock to lock the
# screen before suspend. Use loginctl lock-session to lock your screen.
exec_always --no-startup-id ~/.local/bin/i3-start-xss-lock

# Use wpctl to adjust volume in PipeWire/WirePlumber.
set $refresh_i3status killall -SIGUSR1 i3status
set $audio_sink @DEFAULT_AUDIO_SINK@
set $audio_source @DEFAULT_AUDIO_SOURCE@
bindsym XF86AudioRaiseVolume exec --no-startup-id wpctl set-volume -l 1.0 $audio_sink 5%+ && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id wpctl set-volume $audio_sink 5%- && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id wpctl set-mute $audio_sink toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id wpctl set-mute $audio_source toggle && $refresh_i3status
bindsym $mod+F1 exec --no-startup-id wpctl set-mute $audio_sink toggle && $refresh_i3status
bindsym $mod+F2 exec --no-startup-id wpctl set-volume $audio_sink 5%- && $refresh_i3status
bindsym $mod+F3 exec --no-startup-id wpctl set-volume -l 1.0 $audio_sink 5%+ && $refresh_i3status
bindsym $mod+Shift+F10 exec --no-startup-id wpctl set-mute $audio_source toggle && $refresh_i3status
bindsym $mod+Shift+a exec --no-startup-id ~/.local/bin/i3-audio-menu

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# move tiling windows via drag & drop by left-clicking into the title bar,
# or left-clicking anywhere into the window while holding the floating modifier.
tiling_drag modifier titlebar

# Spacing between tiled windows and screen edges.
gaps inner 8px
gaps outer 4px
smart_gaps off

# start a terminal
bindsym $mod+Return exec --no-startup-id ~/.local/bin/kitty

# start browser
bindsym $mod+b exec --no-startup-id qutebrowser

# start file manager
bindsym $mod+Shift+f exec --no-startup-id thunar

# kill focused window
bindsym $mod+Shift+q kill

# lock screen
bindsym $mod+Shift+x exec --no-startup-id ~/.local/bin/i3-lock-screen

# monitor layout menu
bindsym $mod+p exec --no-startup-id ~/.local/bin/i3-monitor-layout menu
bindsym XF86Display exec --no-startup-id ~/.local/bin/i3-monitor-layout menu

# keyboard layout menu
bindsym $mod+Shift+i exec --no-startup-id ~/.local/bin/i3-keyboard-layout menu
bindsym XF86Keyboard exec --no-startup-id ~/.local/bin/i3-keyboard-layout menu

# network and bluetooth menus
bindsym $mod+Shift+w exec --no-startup-id ~/.local/bin/i3-network-menu
bindsym XF86WLAN exec --no-startup-id ~/.local/bin/i3-network-menu
bindsym $mod+Shift+b exec --no-startup-id ~/.local/bin/i3-bluetooth-menu
bindsym XF86Bluetooth exec --no-startup-id ~/.local/bin/i3-bluetooth-menu

# start an application launcher
bindsym $mod+d exec --no-startup-id ~/.local/bin/i3-app-launcher apps
bindsym $mod+Shift+d exec --no-startup-id ~/.local/bin/i3-app-launcher run
bindsym $mod+Tab exec --no-startup-id ~/.local/bin/i3-app-launcher window

# clipboard manager
bindsym $mod+c exec --no-startup-id ~/.local/bin/i3-clipboard-menu show
bindsym $mod+Shift+v exec --no-startup-id ~/.local/bin/i3-clipboard-menu window
bindsym $mod+Control+c exec --no-startup-id ~/.local/bin/i3-clipboard-menu menu
bindsym $mod+Control+v exec --no-startup-id ~/.local/bin/i3-clipboard-menu paste

# notification controls
bindsym $mod+n exec --no-startup-id dunstctl close
bindsym $mod+Shift+n exec --no-startup-id dunstctl close-all
bindsym $mod+Control+n exec --no-startup-id dunstctl history-pop
bindsym $mod+Shift+Control+n exec --no-startup-id dunstctl set-paused toggle

# screenshots
bindsym Print exec --no-startup-id ~/.local/bin/i3-screenshot area-copy
bindsym Shift+Print exec --no-startup-id ~/.local/bin/i3-screenshot full-copy
bindsym Control+Print exec --no-startup-id ~/.local/bin/i3-screenshot window-copy
bindsym $mod+Print exec --no-startup-id ~/.local/bin/i3-screenshot area-save
bindsym $mod+Shift+Print exec --no-startup-id ~/.local/bin/i3-screenshot full-save
bindsym $mod+Control+Print exec --no-startup-id ~/.local/bin/i3-screenshot window-save
# A more modern dmenu replacement is rofi:
# bindcode $mod+40 exec "rofi -modi drun,run -show drun"
# There also is i3-dmenu-desktop which only displays applications shipping a
# .desktop file. It is a wrapper around dmenu, so you need that installed.
# bindcode $mod+40 exec --no-startup-id i3-dmenu-desktop

# change focus
bindsym $mod+j focus left
bindsym $mod+k focus down
bindsym $mod+l focus up
bindsym $mod+semicolon focus right

# alternatively, you can use the cursor keys:
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# move focused window
bindsym $mod+Shift+j move left
bindsym $mod+Shift+k move down
bindsym $mod+Shift+l move up
bindsym $mod+Shift+semicolon move right

# alternatively, you can use the cursor keys:
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# split in horizontal orientation
bindsym $mod+h split h

# split in vertical orientation
bindsym $mod+v split v

# enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle

# change container layout (stacked, tabbed, toggle split)
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# focus the parent container
bindsym $mod+a focus parent

# focus the child container
#bindsym $mod+d focus child

# Define names for default workspaces for which we configure key bindings later on.
# We use variables to avoid repeating the names in multiple places.
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# reload the configuration file
bindsym $mod+Shift+c reload
# restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $mod+Shift+r restart
# power menu
bindsym $mod+Shift+e exec --no-startup-id ~/.local/bin/i3-power-menu

# resize window (you can also use the mouse for that)
mode "resize" {
        # These bindings trigger as soon as you enter the resize mode

        # Pressing left will shrink the window’s width.
        # Pressing right will grow the window’s width.
        # Pressing up will shrink the window’s height.
        # Pressing down will grow the window’s height.
        bindsym j resize shrink width 10 px or 10 ppt
        bindsym k resize grow height 10 px or 10 ppt
        bindsym l resize shrink height 10 px or 10 ppt
        bindsym semicolon resize grow width 10 px or 10 ppt

        # same bindings, but for the arrow keys
        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt

        # back to normal: Enter or Escape or $mod+r
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}

bindsym $mod+r mode "resize"

# Start i3bar to display a workspace bar (plus the system information i3status
# finds out, if available)
bar {
        status_command ~/.local/bin/i3status-wrapper
        position top
        output primary
        font pango:JetBrains Mono 12
        height 32
        tray_padding 4
        tray_output primary
        workspace_min_width 40
        separator_symbol " | "

        colors {
                background $ctp_mantle
                statusline $ctp_text
                separator $ctp_overlay0

                focused_workspace  $ctp_mauve    $ctp_mauve    $ctp_crust
                active_workspace   $ctp_surface1 $ctp_surface1 $ctp_text
                inactive_workspace $ctp_mantle   $ctp_mantle   $ctp_subtext0
                urgent_workspace   $ctp_red      $ctp_red      $ctp_crust
                binding_mode       $ctp_peach    $ctp_peach    $ctp_crust
        }
}
