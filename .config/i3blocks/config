# i3blocks config for i3bar.

separator=false
separator_block_width=0
markup=none

[notifications]
command=~/.local/bin/i3blocks-status notifications
separator=false
separator_block_width=0
interval=10
signal=10

[network]
command=~/.local/bin/i3blocks-status network
separator=false
separator_block_width=0
interval=10
signal=11

[battery]
command=~/.local/bin/i3blocks-status battery
separator=false
separator_block_width=0
interval=30
signal=14

[disk]
command=~/.local/bin/i3blocks-status disk
separator=false
separator_block_width=0
interval=60

[memory]
command=~/.local/bin/i3blocks-status memory
separator=false
separator_block_width=0
interval=5

[cpu]
command=~/.local/bin/i3blocks-status cpu
separator=false
separator_block_width=0
interval=5

[load]
command=~/.local/bin/i3blocks-status load
separator=false
separator_block_width=0
interval=5

[media]
command=~/.local/bin/i3blocks-status media
separator=false
separator_block_width=0
interval=5
signal=16

[radio]
command=~/.local/bin/i3blocks-status radio
separator=false
separator_block_width=0
interval=5
signal=17

[volume]
command=~/.local/bin/i3blocks-status volume
separator=false
separator_block_width=0
interval=10
signal=12

[pomodoro]
command=~/.local/bin/i3-pomodoro status
separator=false
separator_block_width=0
interval=1
signal=15

[time]
command=~/.local/bin/i3blocks-status time
separator=false
separator_block_width=0
interval=30
