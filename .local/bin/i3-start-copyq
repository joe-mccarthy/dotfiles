#!/bin/sh

notify() {
        if command -v dunstify >/dev/null 2>&1; then
                dunstify "$1" "$2"
        fi
}

cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}"
log_file="$cache_dir/i3-copyq.log"
copyq_bin=$(command -v copyq 2>/dev/null || true)

if [ -z "$copyq_bin" ] && [ -x /usr/bin/copyq ]; then
        copyq_bin="/usr/bin/copyq"
fi

mkdir -p "$cache_dir"
printf 'Starting CopyQ with DISPLAY=%s PATH=%s\n' "${DISPLAY:-unset}" "${PATH:-unset}" >"$log_file"

if [ -z "$copyq_bin" ]; then
        printf 'copyq not found\n' >>"$log_file"
        notify "Clipboard" "CopyQ is not installed"
        exit 0
fi

printf 'Using %s\n' "$copyq_bin" >>"$log_file"

set_option() {
        option="$1"
        value="$2"

        if "$copyq_bin" --start-server config "$option" "$value" >>"$log_file" 2>&1; then
                printf 'Set %s=%s\n' "$option" "$value" >>"$log_file"
                return 0
        fi

        status=$?
        printf 'Failed to set %s=%s: %s\n' "$option" "$value" "$status" >>"$log_file"
        return "$status"
}

set_option disable_tray true || exit $?
set_option hide_main_window true || exit $?
set_option clipboard_notification_lines 0 || exit $?
set_option item_popup_interval 0 || exit $?

if "$copyq_bin" count >/dev/null 2>&1; then
        printf 'CopyQ server reachable\n' >>"$log_file"
        exit 0
fi

printf 'CopyQ server was configured but is not reachable\n' >>"$log_file"
exit 1
