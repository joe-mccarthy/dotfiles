#!/bin/sh

i3status_config="$HOME/.config/i3status/config"
theme_env="$HOME/.config/i3/theme.env"

if [ -r "$theme_env" ]; then
        set -a
        # shellcheck disable=SC1090
        . "$theme_env"
        set +a
fi

network_good="${CTP_GREEN:-#a6d189}"
network_degraded="${CTP_YELLOW:-#e5c890}"
network_bad="${CTP_RED:-#e78284}"

json_block() {
        name="$1"
        color="$2"
        text="$3"

        if command -v jq >/dev/null 2>&1; then
                jq -cn --arg name "$name" --arg color "$color" --arg text "$text" \
                        '{name:$name,color:$color,markup:"none",full_text:$text}'
        else
                printf '{"name":"%s","color":"%s","markup":"none","full_text":"%s"}' "$name" "$color" "$text"
        fi
}

primary_network_line() {
        nmcli -t -f DEVICE,TYPE,STATE,CONNECTION device status 2>/dev/null | awk -F: '
                $3 ~ /^connected/ &&
                $1 !~ /^(lo|docker[0-9]*|br-|veth|p2p-)/ &&
                $2 !~ /^(bridge|loopback|dummy|tun)$/ {
                        print
                        exit
                }
        '
}

active_vpn() {
        nmcli -t -f TYPE,NAME connection show --active 2>/dev/null | awk -F: '
                $1 == "vpn" || $1 == "wireguard" {
                        gsub(/\\:/, ":", $2)
                        print $2
                        exit
                }
        '
}

device_ip() {
        nmcli -g IP4.ADDRESS device show "$1" 2>/dev/null | awk 'NR == 1 {
                sub(/\/.*/, "", $0)
                print
        }'
}

network_block() {
        vpn=$(active_vpn)
        line=$(primary_network_line)

        if [ -z "$line" ]; then
                if [ -n "$vpn" ]; then
                        json_block network "$network_degraded" "NET VPN $vpn"
                else
                        json_block network "$network_bad" "NET down"
                fi
                return
        fi

        device=$(printf '%s\n' "$line" | awk -F: '{ print $1 }')
        type=$(printf '%s\n' "$line" | awk -F: '{ print $2 }')
        connection=$(printf '%s\n' "$line" | awk -F: '{ print $4 }')
        ip_addr=$(device_ip "$device")

        case "$type" in
                wifi)
                        label="${connection:-WIFI}"
                        ;;
                ethernet)
                        label="LAN"
                        ;;
                *)
                        label="${connection:-$type}"
                        ;;
        esac

        text="NET $label"
        [ -n "$ip_addr" ] && text="$text $ip_addr"
        [ -n "$vpn" ] && text="$text VPN"

        if [ -n "$ip_addr" ]; then
                json_block network "$network_good" "$text"
        else
                json_block network "$network_degraded" "$text"
        fi
}

notification_block() {
        "$HOME/.local/bin/i3-notifications" status-json 2>/dev/null || true
}

status_prefix() {
        notifications=$(notification_block)
        network=$(network_block)

        if [ -n "$notifications" ]; then
                printf '%s,%s' "$notifications" "$network"
        else
                printf '%s' "$network"
        fi
}

i3status -c "$i3status_config" | while IFS= read -r line; do
        case "$line" in
                '[' | '{"version":1}')
                        printf '%s\n' "$line"
                        ;;
                ,\[*)
                        data=${line#,}
                        data=${data#?}
                        printf ',[%s,%s\n' "$(status_prefix)" "$data"
                        ;;
                \[*)
                        data=${line#?}
                        printf '[%s,%s\n' "$(status_prefix)" "$data"
                        ;;
                *)
                        printf '%s\n' "$line"
                        ;;
        esac
done
