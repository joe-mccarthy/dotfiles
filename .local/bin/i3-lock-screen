#!/bin/sh

lock_color="1d2021"

lock_screen() {
        exec i3lock -n -e -f -c "$lock_color"
}

lock_for_suspend() {
        i3lock -n -e -f -c "$lock_color" &
        sleep 0.2
        systemctl suspend
}

case "${1:-lock}" in
        lock|--nofork)
                lock_screen
                ;;
        suspend)
                lock_for_suspend
                ;;
        *)
                printf 'usage: %s [lock|--nofork|suspend]\n' "$0" >&2
                exit 2
                ;;
esac
