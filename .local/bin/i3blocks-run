#!/bin/sh

if command -v i3blocks >/dev/null 2>&1; then
        i3blocks_bin=$(command -v i3blocks)
else
        fallback="$HOME/.local/opt/i3blocks/usr/bin/i3blocks"
        if [ -x "$fallback" ]; then
                i3blocks_bin="$fallback"
        else
                printf 'i3blocks not found. Install the i3blocks package.\n' >&2
                exit 127
        fi
fi

"$i3blocks_bin" "$@" | sed -u 's/{"":"",/{/g'
