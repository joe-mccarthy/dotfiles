#!/bin/sh

theme="$HOME/.config/rofi/i3-launcher.rasi"
dmenu_style="-i -l 14 -p clipboard -fn monospace:size=12 -nb #1d2021 -nf #ebdbb2 -sb #8ec07c -sf #1d2021"

notify() {
        if command -v dunstify >/dev/null 2>&1; then
                dunstify "$1" "$2"
        fi
}

choose() {
        prompt="$1"
        options="$2"

        if command -v rofi >/dev/null 2>&1; then
                printf '%s\n' "$options" | rofi -dmenu -i -p "$prompt" -theme "$theme"
        else
                # shellcheck disable=SC2086
                printf '%s\n' "$options" | dmenu $dmenu_style
        fi
}

confirm() {
        action="$1"
        choice=$(choose "$action" "No
Yes")
        [ "$choice" = "Yes" ]
}

ensure_copyq() {
        if ! command -v copyq >/dev/null 2>&1; then
                notify "Clipboard" "CopyQ is not installed"
                exit 1
        fi

        if ! pgrep -u "$USER" -x copyq >/dev/null 2>&1; then
                if ! copyq --start-server config disable_tray true >/dev/null 2>&1; then
                        copyq >/dev/null 2>&1 &
                fi
        fi

        tries=0
        while [ "$tries" -lt 20 ]; do
                if copyq -e "monitoring()" >/dev/null 2>&1; then
                        copyq config disable_tray true >/dev/null 2>&1 || true
                        copyq config hide_main_window true >/dev/null 2>&1 || true
                        copyq config clipboard_notification_lines 0 >/dev/null 2>&1 || true
                        copyq config item_popup_interval 0 >/dev/null 2>&1 || true
                        return 0
                fi

                tries=$((tries + 1))
                sleep 0.1
        done

        notify "Clipboard" "CopyQ is not ready"
        exit 1
}

copyq_script() {
        script="$1"

        if ! copyq -e "$script" >/dev/null 2>&1; then
                notify "Clipboard" "CopyQ command failed"
                exit 1
        fi
}

history_items() {
        if ! copyq eval -- '
function clean(value) {
    return str(value).replace(/[\t\r\n]+/g, " ").replace(/\s+/g, " ").replace(/^\s+|\s+$/g, "");
}

function itemData(mime, row) {
    try {
        return clean(read(mime, row));
    } catch (e) {
        return "";
    }
}

function shorten(value, limit) {
    if (value.length <= limit) {
        return value;
    }

    return value.substring(0, limit - 3) + "...";
}

var total = size();
for (var i = 0; i < total; ++i) {
    var label = itemData(mimeText, i);
    var source = itemData(mimeWindowTitle, i);
    var formats = "";
    var kind = "[TXT]";

    if (!label) {
        try {
            formats = str(read("?", i));
        } catch (e) {
            formats = "";
        }

        if (formats.indexOf("text/uri-list") !== -1) {
            kind = "[URI]";
            label = itemData(mimeUriList, i).replace(/^file:\/\//, "");
        } else if (formats.indexOf("image/") !== -1) {
            kind = "[IMG]";
            label = "[image]";
        } else if (formats.indexOf("text/html") !== -1) {
            kind = "[HTML]";
            label = clean(itemData(mimeHtml, i).replace(/<[^>]*>/g, " "));
        } else {
            kind = "[DATA]";
            label = "[non-text item]";
        }
    }

    label = shorten(label, source ? 110 : 140);
    if (source) {
        label += "  (" + shorten(source, 28) + ")";
    }

    var number = i + 1;
    var displayNumber = number < 10 ? "0" + number : "" + number;
    print(i + "\t" + displayNumber + " " + kind + " " + label + "\n");
}
' 2>/dev/null; then
                notify "Clipboard" "Could not read CopyQ history"
                exit 1
        fi
}

pick_history() {
        prompt="$1"

        ensure_copyq
        items=$(history_items)

        if [ -z "$items" ]; then
                notify "Clipboard" "History is empty"
                return 1
        fi

        selection=$(choose "$prompt" "$items")
        [ -n "$selection" ] || return 1

        row=$(printf '%s\n' "$selection" | awk -F '\t' '{ print $1 }')
        case "$row" in
                ""|*[!0-9]*)
                        notify "Clipboard" "Could not parse selection"
                        return 2
                        ;;
        esac

        printf '%s\n' "$row"
}

copy_history() {
        row=$(pick_history "clipboard") || exit 0
        copyq_script "select($row)"
        notify "Clipboard" "Copied item $((row + 1))"
}

paste_history() {
        row=$(pick_history "paste") || exit 0
        copyq_script "select($row); paste()"
}

delete_history() {
        row=$(pick_history "delete") || exit 0
        copyq_script "remove($row)"
        notify "Clipboard" "Deleted item $((row + 1))"
}

show_window() {
        ensure_copyq
        copyq_script "toggle()"
}

show_items() {
        ensure_copyq
        copyq_script "menu()"
}

pause_capture() {
        ensure_copyq
        copyq_script "disable()"
        notify "Clipboard" "Capture paused"
}

resume_capture() {
        ensure_copyq
        copyq_script "enable()"
        notify "Clipboard" "Capture resumed"
}

clear_history() {
        ensure_copyq
        confirm "clear clipboard history" || exit 0
        copyq_script "while (size() > 0) remove(0)"
        notify "Clipboard" "History cleared"
}

quit_copyq() {
        ensure_copyq
        copyq_script "exit()"
}

manage_menu() {
        selection=$(choose "clipboard" "Copy History
Paste History
Delete Item
CopyQ Window
CopyQ Item Menu
Pause Capture
Resume Capture
Clear History
Quit CopyQ")

        case "$selection" in
                "Copy History") copy_history ;;
                "Paste History") paste_history ;;
                "Delete Item") delete_history ;;
                "CopyQ Window") show_window ;;
                "CopyQ Item Menu") show_items ;;
                "Pause Capture") pause_capture ;;
                "Resume Capture") resume_capture ;;
                "Clear History") clear_history ;;
                "Quit CopyQ") quit_copyq ;;
                "") exit 0 ;;
                *)
                        notify "Clipboard" "Unknown option: $selection"
                        exit 1
                        ;;
        esac
}

case "${1:-show}" in
        show|history|rofi|picker|copy) copy_history ;;
        paste) paste_history ;;
        delete|remove) delete_history ;;
        window) show_window ;;
        items) show_items ;;
        pause) pause_capture ;;
        resume) resume_capture ;;
        clear) clear_history ;;
        quit) quit_copyq ;;
        menu|manage) manage_menu ;;
        *)
                printf 'usage: %s [show|paste|delete|window|items|menu|pause|resume|clear|quit]\n' "$0" >&2
                exit 2
                ;;
esac
